{
  "name": "slapshot-club-backend",
  "version": "0.1.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:push": "tsx --env-file=.env node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx --env-file=.env node_modules/drizzle-kit/bin.cjs studio",
    "db:generate": "tsx --env-file=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:dev": "tsx src/db/migrate.ts",
    "db:push:test": "tsx --env-file=.env.test node_modules/drizzle-kit/bin.cjs push",
    "db:generate:test": "tsx --env-file=.env.test node_modules/drizzle-kit/bin.cjs generate",
    "db:studio:test": "tsx --env-file=.env.test node_modules/drizzle-kit/bin.cjs studio",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "start:prod": "npm run db:migrate && npm run start",
    "test": "dotenv -e .env.test -- vitest",
    "seed:admin": "tsx --env-file=.env src/db/seed/index.ts",
    "seed:users": "tsx --env-file=.env src/db/seed/users.ts",
    "db:migrate-old-data": "tsx --env-file=.env scripts/migrate-data.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@logtail/pino": "^0.5.8",
    "@paralleldrive/cuid2": "^3.3.0",
    "@sindresorhus/slugify": "^3.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "bullmq": "^5.70.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}

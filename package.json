{
  "name": "slapshot-club-root",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:down:delete": "docker-compose down -v",
    "db:wait": "node -e \"setTimeout(() => process.exit(0), 3000)\"",
    "backend:setup": "npm --prefix backend run db:migrate && npm --prefix backend run seed:admin",
    "db:setup": "npm run docker:up && npm run db:wait && npm run backend:setup",
    "be:dev": "npm --prefix backend run dev",
    "fe:dev": "npm --prefix frontend run dev",
    "dev": "npm run be:dev & npm run fe:dev",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "push": "git push --follow-tags origin main",
    "push:prod": "git push --follow-tags origin production",
    "db:generate": "npm --prefix backend run db:generate",
    "db:migrate": "npm --prefix backend run db:migrate"
  },
  "devDependencies": {
    "standard-version": "^9.5.0"
  }
}
